/* App core overlay for the Whear project.
 *
 * The RFID UART (P1.04/P1.05) is handled by the network core — the app
 * core does not need any additional UART configuration.
 *
 * Reserve the shared-memory region so Zephyr doesn't allocate over it.
 */

/ {
    reserved-memory {
        #address-cells = <1>;
        #size-cells = <1>;
        ranges;

        /* Last 1 KB of net core RAM — IPC mailbox shared with net core */
        ipc_shmem: memory@2100FC00 {
            reg = <0x2100FC00 0x400>;
        };
    };
};
